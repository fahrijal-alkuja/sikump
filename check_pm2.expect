#!/usr/bin/expect -f

set timeout 30
set host "31.97.106.132"
set user "root"
set password "alkuja07"

spawn ssh -o StrictHostKeyChecking=no $user@$host "export PATH=/usr/local/bin:/usr/bin:/bin:/www/server/nodejs/v20.x/bin:/www/server/nodejs/v22.x/bin && pm2 list"

expect {
    "Enter passphrase for key" {
        send "$password\r"
        exp_continue
    }
    eof
}
