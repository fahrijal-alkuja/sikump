#!/usr/bin/expect -f
set timeout 60
set host "31.97.106.132"
set user "root"
set password "alkuja07"
spawn ssh -o StrictHostKeyChecking=no $user@$host "pm2 logs sikump --lines 50 --nostream"
expect {
    "password:" {
        send "$password\r"
        exp_continue
    }
    "Enter passphrase for key" {
        send "$password\r"
        exp_continue
    }
    eof
}
